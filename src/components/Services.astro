---
const services = [
  {
    title: "Preventive Care",
    description: "Cleanings, exams, hygiene coaching, and routine family visits.",
    tone: "bg-air",
  },
  {
    title: "Restorative Care",
    description: "Crowns, fillings, bridges, and treatment planning for worn or damaged teeth.",
    tone: "bg-sand",
    delay: "80ms",
  },
  {
    title: "Emergency & Extractions",
    description: "Support for urgent concerns, tooth pain, oral surgery, and wisdom teeth.",
    tone: "bg-powder",
    delay: "160ms",
  },
  {
    title: "Root Canal Therapy",
    description: "Thoughtful care when a tooth needs deeper treatment.",
    tone: "bg-powder",
  },
  {
    title: "Dentures & Bridges",
    description: "Practical tooth replacement options for comfort and confidence.",
    tone: "bg-air",
    delay: "80ms",
  },
  {
    title: "Cosmetic Dentistry",
    description: "Personalized enhancements to help your smile feel like you.",
    tone: "bg-navy text-white",
    bodyTone: "text-white/70",
    delay: "160ms",
  },
];
---

<section id="choose" class="px-4 py-14 sm:py-16">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold tracking-[.22em] text-eucalyptus uppercase sm:text-sm">Choose your care</p>
      <h2 class="mt-4 font-heading text-4xl leading-tight md:text-6xl">A boutique-style menu for everyday oral health.</h2>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <article
          class:list={["reveal min-h-[155px] rounded-4xl p-6 sm:min-h-[175px] sm:rounded-5xl sm:p-7", service.tone]}
          style={service.delay ? `--reveal-delay:${service.delay}` : undefined}
        >
          <h3 class="text-2xl font-bold">{service.title}</h3>
          <p class:list={["mt-3", service.bodyTone ?? "text-body"]}>{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
