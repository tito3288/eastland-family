---
const faqs = [
  {
    question: "Do you see families and adults?",
    answer: "Yes. Eastland Family Dental provides family-focused care for routine and ongoing oral health needs.",
  },
  {
    question: "Can I call for urgent dental concerns?",
    answer: "Call the office so the team can help you determine the best next step for tooth pain, swelling, or injury.",
    delay: "80ms",
  },
  {
    question: "Where is the office?",
    answer: "19401 East US Highway 40 Ste. 180, Independence, MO 64055.",
    delay: "160ms",
  },
];
---

<section id="faq" class="px-4 py-14 sm:py-16">
  <div class="mx-auto max-w-4xl">
    <h2 class="reveal text-center font-heading text-4xl leading-tight md:text-6xl">Before your first visit</h2>
    <div class="mt-10 space-y-3">
      {faqs.map((item) => (
        <details class="reveal glow rounded-3xl bg-white p-5 sm:p-6" style={item.delay ? `--reveal-delay:${item.delay}` : undefined}>
          <summary class="cursor-pointer font-bold">{item.question}</summary>
          <p class="mt-3 text-body">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
